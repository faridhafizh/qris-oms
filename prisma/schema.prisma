generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           Int            @id @default(autoincrement())
  email        String         @unique
  password     String
  role         String         // Changed from enum Role to String to avoid sqlite alter enum issues, or we can use String
  namaLengkap  String
  region       String?        // Added region for Pemda
  createdAt    DateTime       @default(now())
  checklists   Checklist[]
  auditChanges AuditLog[]     @relation("AuditChangedBy")
  notifications Notification[]
}

model Merchant {
  id           Int            @id @default(autoincrement())
  name         String
  category     String
  status       String         // prospect, in_progress, completed
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  checklists   Checklist[]
}

model Campaign {
  id           Int            @id @default(autoincrement())
  name         String
  target       String
  startDate    DateTime
  endDate      DateTime
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  checklists   Checklist[]
}

model Notification {
  id           Int            @id @default(autoincrement())
  userId       Int
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  message      String
  isRead       Boolean        @default(false)
  createdAt    DateTime       @default(now())
}

model Checklist {
  id                Int        @id @default(autoincrement())
  checklistCode     String     @unique
  pjpId             Int
  pjp               User       @relation(fields: [pjpId], references: [id])
  tanggalKunjungan  DateTime
  provinsi          String
  kabupaten         String
  kecamatan         String
  desa              String
  segmen            String     // Changed from enum Segmen
  namaMerchant      String
  sudahDiedukasi    Boolean
  bersediaOnboarding Boolean
  alasanPenolakan   String?
  fotoUrl           String?
  catatan           String?
  submittedAt       DateTime   @default(now())
  statusSla         String     // Changed from enum StatusSLA
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  audits            AuditLog[]
  merchantId        Int?
  merchant          Merchant?  @relation(fields: [merchantId], references: [id])
  campaignId        Int?
  campaign          Campaign?  @relation(fields: [campaignId], references: [id])
  dynamicData       String?    // Storing JSON string
}

model AuditLog {
  id          Int       @id @default(autoincrement())
  checklistId Int
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  changedById Int
  changedBy   User      @relation("AuditChangedBy", fields: [changedById], references: [id])
  fieldName   String
  oldValue    String?
  newValue    String?
  changedAt   DateTime  @default(now())
}
