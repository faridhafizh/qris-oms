<%- include('partials/header', { title: 'Register', user: null }) %>
<div class="card" style="max-width:520px;margin:auto;">
  <h2>Registrasi</h2>
  <% if (error) { %><p class="badge red"><%= error %></p><% } %>
  <form method="post" action="/register" class="grid">
    <div><label>Nama Lengkap</label><input name="nama_lengkap" required /></div>
    <div><label>Email</label><input name="email" type="email" required /></div>
    <div><label>Password</label><input name="password" type="password" minlength="6" required /></div>
    <div>
      <label>Role</label>
      <select name="role" required>
        <option value="PJP">PJP</option>
        <option value="BI">BI</option>
        <option value="Pemda">Pemda</option>
        <option value="Local_Champion">Local Champion</option>
      </select>
    </div>
    <div>
      <label>Wilayah / Region (Opsional untuk Pemda & Local Champion)</label>
      <input name="region" placeholder="Misal: Jawa Barat" />
    </div>
    <div style="display: flex; gap: 1rem; margin-top: 0.5rem;">
      <a href="/login" class="btn secondary" style="flex: 1; text-align: center;">Batal</a>
      <button class="btn" type="submit" style="flex: 1;">Daftar</button>
    </div>
  </form>
</div>
<%- include('partials/footer') %>
